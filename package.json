{
  "name": "echolect",
  "version": "0.1.0",
  "description": "A real-time meeting copilot — live transcription, speaker naming, and on-demand AI assistance.",
  "license": "GPL-3.0-or-later",
  "author": "ah2k (https://ah2k.dev)",
  "homepage": "https://ah2k.dev",
  "repository": "https://github.com/ah2k-dev/echolect",
  "private": true,
  "main": "dist/main/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n vite,app -c cyan,green \"vite\" \"wait-on tcp:127.0.0.1:5174 && npm run build:electron && electron dist/main/main/index.js\"",
    "dev:renderer": "vite",
    "dev:electron": "wait-on tcp:127.0.0.1:5174 && npm run build:electron && electron dist/main/main/index.js",
    "build": "tsc && vite build",
    "build:electron": "tsc -p tsconfig.main.json && tsc -p tsconfig.preload.json",
    "start": "electron dist/main/main/index.js",
    "test": "cross-env ELECTRON_RUN_AS_NODE=1 electron node_modules/vitest/vitest.mjs run",
    "test:watch": "cross-env ELECTRON_RUN_AS_NODE=1 electron node_modules/vitest/vitest.mjs",
    "package": "npm run build && npm run build:electron && electron-builder",
    "postinstall": "electron-rebuild"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.1",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@testing-library/svelte": "^5.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "jsdom": "^25.0.0",
    "svelte": "^5.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0",
    "wait-on": "^8.0.2"
  },
  "dependencies": {
    "@types/ws": "^8.18.1",
    "better-sqlite3": "^11.0.0",
    "ws": "^8.20.1"
  }
}
